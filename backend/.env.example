# ----------------------------------------------------------------------------
# E&E / Focus 9 Distribution Middleware - environment configuration
# Copy this file to ".env" and fill in real values. NEVER commit .env.
# (Security doc: "Never embed sensitive passwords or API secrets directly in
#  the mobile app code" -> all secrets live here, server-side only.)
# ----------------------------------------------------------------------------

NODE_ENV=development
PORT=4000

# --- Data backend -----------------------------------------------------------
# 'file' = local JSON store (zero setup, for local dev)
# 'postgres' = Supabase. Auto-selected when DATABASE_URL is present (e.g. Vercel).
DATA_BACKEND=file
# Supabase connection string. Use the CONNECTION POOLER URL (port 6543,
# "Transaction" mode) for serverless/Vercel. Found in:
# Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI.
# Example: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- JWT / session security -------------------------------------------------
# Generate strong random values, e.g.  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- MFA / OTP --------------------------------------------------------------
OTP_TTL_SECONDS=300
# In production OTP is delivered by SMS/email provider. In dev it is returned
# in the API response / logged so the flow can be exercised without a gateway.
OTP_DELIVERY=dev

# --- Focus 9 ERP connector --------------------------------------------------
# These come from Focus Softnet (see System Requirement doc "Getting Started").
# FOCUS9_MODE=mock uses the built-in simulator; FOCUS9_MODE=live calls the URL.
FOCUS9_MODE=mock
FOCUS9_BASE_URL=https://your-focus9-instance.example.com/api
FOCUS9_INTEGRATION_USER=integration-api-user
FOCUS9_API_KEY=change-me-focus9-api-key
FOCUS9_COMPANY_CODE=EE01

# --- PROSAFE connector (E&E personnel / asset validation) -------------------
PROSAFE_MODE=mock
PROSAFE_BASE_URL=https://prosafe.example.com/api
PROSAFE_API_KEY=change-me-prosafe-api-key

# --- Network security -------------------------------------------------------
# Comma-separated allowed origins for CORS.
CORS_ORIGINS=http://localhost:4000
# Set to 1 to enable HTTPS using certs in ./certs (server.key / server.crt).
ENABLE_HTTPS=0
# Set to 1 to disable auth/API rate limiting (unlimited login attempts). Dev only.
RATE_LIMIT_DISABLED=0
